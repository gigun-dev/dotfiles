{
  "icon_theme": "Catppuccin Latte",
  "theme": "One Dark",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "tab_size": 2,
  "hard_tabs": true,
  "show_whitespaces": "all",
  "format_on_save": "on",
  "formatter": "prettier",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "languages": {
    "Markdown": {
      "format_on_save": "off",
      "hard_tabs": false
    }
  }
}
