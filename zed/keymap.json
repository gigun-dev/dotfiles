[
  {
    // Workspace context: Ctrl+J → bottom dock (terminal)、Ctrl+L → agent panel
    "context": "Workspace",
    "bindings": {
      "ctrl-j": "workspace::ToggleBottomDock",
      "ctrl-l": "agent::ToggleFocus"
    }
  },
  {
    // Editor context は default で ctrl-l が editor::SelectLine に bind されている
    // (default-windows.json L114) ため override が必要。これがないと editor focus 時
    // のみ「閉じるしかできない」見かけになる
    "context": "Editor",
    "bindings": {
      "ctrl-l": "agent::ToggleFocus"
    }
  },
  {
    // Agent panel focus 中は agent::ToggleFocus だと close しない (focus 状態維持)。
    // Zed default の ctrl-shift-i と同じく workspace::ToggleRightDock を使えば
    // 右 dock ごと閉じる。これで editor/AgentPanel 両方で正しい open/close toggle に。
    "context": "AgentPanel || MessageEditor > Editor",
    "bindings": {
      "ctrl-l": "workspace::ToggleRightDock"
    }
  }
]
