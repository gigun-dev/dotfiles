[
  {
    // Workspace context: Ctrl+J → bottom dock (terminal)、Ctrl+L → agent panel
    "context": "Workspace",
    "bindings": {
      "ctrl-j": "workspace::ToggleBottomDock",
      "ctrl-l": "agent::ToggleFocus"
    }
  },
  {
    // Editor context は default で ctrl-l が editor::SelectLine に bind されている
    // (default-windows.json L114) ため override が必要。これがないと editor focus 時
    // のみ「閉じるしかできない」見かけになる
    "context": "Editor",
    "bindings": {
      "ctrl-l": "agent::ToggleFocus"
    }
  }
]
